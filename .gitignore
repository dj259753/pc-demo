node_modules/
.DS_Store

# 大型模型文件（onnx / bin）不上传
models/
*.onnx
*.bin

# tools 里的构建产物（wasm/ruffle 等）
tools/*.wasm
tools/core.ruffle.*.js
tools/ruffle.js

# Electron 构建产物
dist/
release/*.zip
# Gateway 资源可提交。runtime/node（及 Windows 的 node.exe）用 Git LFS 跟踪，见 .gitattributes
# 克隆后: git lfs install && git lfs pull；无 LFS 时仍可用 CDN / npm run ensure:runtime-node
# 若仍从 QQClaw 同步见 npm run prepare:gateway